{
  "manifest_version": 3,
  "name": "Gmail 一鍵翻譯 — 台灣慣用語中文",
  "version": "1.2.0",
  "description": "在 Gmail 中一鍵將英文信件翻譯為台灣繁體中文",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["style.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png"
  }
}
